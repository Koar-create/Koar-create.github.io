---
import HomeLayout from '../layouts/HomeLayout.astro';
import Hero from '../components/Hero.astro';
import Reveal from '../components/Reveal.astro';
import EntryCard from '../components/EntryCard.astro';
import { getEntriesForLocale, entrySlug, entryUrl } from '../lib/content';
import { siteConfig, t, localePath } from '../lib/i18n';

const locale = 'en';
const strings = t(locale);
const currentPath = Astro.url.pathname;

const research = await getEntriesForLocale('research', locale);
const featured = research.slice(0, 2);
const blogPosts = (await getEntriesForLocale('blog', locale)).slice(0, 2);
---

<HomeLayout title={strings.home.title} locale={locale} currentPath={currentPath}>
  <Hero
    locale={locale}
    name={strings.sidebar.name}
    role={strings.home.role}
    tagline={strings.home.tagline}
    portrait="/assets/images/Portrait.jpg"
  />

  <section class="home-section container">
    <Reveal variant="mask">
      <span class="label">{strings.home.bioLabel}</span>
      <div class="home-bio">
        <p>
          I am a first-year MPhil student at HKUST Guangzhou. Check
          <a href={siteConfig.social.rbmProgram}>here</a> for the RBM program. My aspiration is a
          PhD focused on atmospheric modeling, CFD, and aerospace/UAS applications.
        </p>
        <p>
          Supervisor:
          <a href={siteConfig.social.scholarSupervisor}>Dr. Henry Zhen Liu</a>. B.Sc. in Atmospheric
          Sciences, Sun Yat-sen University; bachelor's thesis with Dr. Maoqiu Jian.
        </p>
      </div>
    </Reveal>
  </section>

  <section class="home-section container">
    <div class="section-head">
      <h2 class="section-title">{strings.home.featuredLabel}</h2>
      <a href={localePath(locale, '/research')}>{strings.home.featuredLink} →</a>
    </div>
    <Reveal variant="stagger">
      <div class="entry-grid">
        {
          featured.map((entry, i) => (
            <EntryCard
              index={i + 1}
              href={entryUrl('research', locale, entrySlug(entry))}
              title={entry.data.title}
              summary={entry.data.summary}
              date={entry.data.date}
              statusLabel={strings.status[entry.data.status]}
              tags={entry.data.tags}
              locale={locale}
            />
          ))
        }
      </div>
    </Reveal>
  </section>

  {
    blogPosts.length > 0 && (
      <section class="home-section container">
        <div class="section-head">
          <h2 class="section-title">{strings.home.recentLabel}</h2>
          <a href={localePath(locale, '/blog')}>{strings.home.recentLink} →</a>
        </div>
        <Reveal variant="stagger">
          <div class="entry-grid">
            {blogPosts.map((entry, i) => (
              <EntryCard
                index={i + 1}
                href={entryUrl('blog', locale, entrySlug(entry))}
                title={entry.data.title}
                summary={entry.data.summary}
                date={entry.data.pubDate}
                tags={entry.data.tags}
                locale={locale}
              />
            ))}
          </div>
        </Reveal>
      </section>
    )
  }

  <section class="home-section container">
    <Reveal>
      <span class="label">{strings.home.contactLabel}</span>
      <a class="contact-cta" href={`mailto:${siteConfig.email}?Subject=Hello`}>
        {siteConfig.email}
      </a>
      <p style="margin-top: var(--space-lg); color: var(--color-text-muted);">{strings.home.contact}</p>
    </Reveal>
  </section>
</HomeLayout>
