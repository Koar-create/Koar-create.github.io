---
import { formatDate } from '../lib/content';
import type { Locale } from '../lib/i18n';

interface Props {
  href: string;
  title: string;
  summary: string;
  date: Date;
  statusLabel?: string;
  tags?: string[];
  locale: Locale;
  index?: number;
}

const { href, title, summary, date, statusLabel, tags = [], locale, index = 1 } = Astro.props;
const indexLabel = String(index).padStart(2, '0');
---

<a href={href} class="entry-card">
  <span class="entry-card-index">{indexLabel}</span>
  <div class="entry-card-body">
    <h2>{title}</h2>
    <p>{summary}</p>
    <div class="entry-meta">
      <time datetime={date.toISOString()}>{formatDate(date, locale)}</time>
      {statusLabel && <span class="status-badge">{statusLabel}</span>}
    </div>
    {
      tags.length > 0 && (
        <div class="tag-list">
          {tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )
    }
  </div>
</a>
